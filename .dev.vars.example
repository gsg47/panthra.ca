# Copy to .dev.vars for local testing with `npx wrangler pages dev .`

# Cloudflare Turnstile (free)
TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Resend (recommended for contact form email on free Cloudflare plan)
RESEND_API_KEY=re_your_key_here

CONTACT_TO_EMAIL=contact@panthra.ca
CONTACT_FROM_EMAIL=noreply@panthra.ca
